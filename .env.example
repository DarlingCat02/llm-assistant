# === LLM Provider ===
# Провайдер: ollama / lm_studio / openrouter
LLM_PROVIDER=ollama

# URL сервера (для ollama и lm_studio)
# Ollama: http://localhost:11434
# LM Studio: http://localhost:1234
LLM_HOST=http://localhost:11434

# API-ключ (нужен только для openrouter)
# Получить на https://openrouter.ai/keys
LLM_API_KEY=

# Модель для генерации
# Ollama: qwen2.5:7b, llama3.2:3b, mistral:7b
# LM Studio: любая загруженная модель (например, qwen2.5-7b-instruct)
# OpenRouter: openai/gpt-4o, anthropic/claude-3.5-sonnet, google/gemini-pro-1.5, qwen/qwen-2.5-72b-instruct
LLM_MODEL=qwen2.5:7b

# Максимальное количество токенов в контексте (для Ollama)
LLM_NUM_CTX=4096

# Температура генерации (0.0 - детерминировано, 2.0 - креативно)
LLM_TEMPERATURE=0.7


# === Ollama API (устаревшее, для обратной совместимости) ===
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_NUM_CTX=4096
OLLAMA_TEMPERATURE=0.7


# === ChromaDB ===
CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION_NAME=assistant_memory


# === Memory ===
MEMORY_MAX_CONTEXT=20
MEMORY_SEARCH_RESULTS=3
MEMORY_SIMILARITY_THRESHOLD=0.3


# === TTS ===
TTS_ENABLED=false
TTS_MODEL=silero_v3


# === Web Interface ===
WEB_HOST=127.0.0.1
WEB_PORT=8000


# === GUI ===
GUI_ENABLED=false
GUI_FRAMEWORK=customtkinter
GUI_THEME=dark
GUI_TITLE=Local AI Assistant
GUI_WIDTH=900
GUI_HEIGHT=600


# === Voice Service ===
VOICE_HOTKEY=F12
VOICE_MODEL=whisper-tiny


# === Logging ===
LOG_LEVEL=INFO
